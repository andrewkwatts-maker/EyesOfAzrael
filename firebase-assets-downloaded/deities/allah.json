  "keyMyths": [
    {
      "title": "The Creation of Adam",
      "description": "Allah created Adam, the first human, from clay and breathed life into him. The angels were commanded to prostrate before Adam, but Iblis (Satan) refused out of pride, leading to his expulsion from Paradise and becoming a symbol of disobedience.",
      "source": "Quran (various verses, including 2:30-39, 7:11-18)"
    },
    {
      "title": "The Night Journey (Isra and Mi'raj)",
      "description": "The Prophet Muhammad's miraculous night journey from Mecca to Jerusalem (Isra) and his ascension to the heavens (Mi'raj) in the company of the angel Gabriel. During this journey, he met prophets and received instructions from Allah, including the obligation of the five daily prayers.",
      "source": "Quran (17:1) and Hadith collections (Bukhari, Muslim)"
    },
    {
      "title": "The Story of Prophet Ibrahim and the Sacrifice",
      "description": "Allah commanded Prophet Ibrahim (Abraham) to sacrifice his son, Ismail (Ishmael), as a test of faith. Just as Ibrahim was about to carry out the command, Allah intervened and replaced Ismail with a ram, demonstrating Ibrahim's unwavering devotion and establishing the tradition of Eid al-Adha.",
      "source": "Quran (37:100-111)"
    },
    {
      "title": "The Great Flood of Prophet Nuh (Noah)",
      "description": "The story of Prophet Nuh (Noah) who was commanded by Allah to build an ark to save himself, his family, and pairs of animals from a devastating flood sent as punishment for the wickedness of humanity. After the flood subsided, Nuh and his companions repopulated the earth.",
      "source": "Quran (various verses in Surah Hud and other Surahs)"
    },
    {
      "title": "The Angels Harut and Marut",
      "description": "Two angels, Harut and Marut, were sent to Earth to test humanity but succumbed to worldly desires and taught magic to the people. This story serves as a cautionary tale about the dangers of temptation and the importance of resisting evil.",
      "source": "Quran (2:102) and various interpretations in Islamic literature"
    }
  ],
