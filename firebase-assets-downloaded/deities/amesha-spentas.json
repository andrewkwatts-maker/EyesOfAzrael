  "cultural": {
    "worshipPractices": [
      {
        "name": "Fire Temples",
        "description": "Fire temples, also known as Atashgahs, served as central places of worship where a sacred flame was perpetually kept burning. The fire symbolized purity, truth, and the divine presence of Ahura Mazda. Priests, known as Magi, tended to the fire and performed rituals and prayers."
      },
      {
        "name": "Yazata Devotion",
        "description": "Devotion to the Yazatas, benevolent divine beings, involved prayers, offerings, and acts of piety. Each Yazata represented a specific virtue or aspect of creation, and individuals would seek their blessings for various needs and aspirations. This included reciting Avestan hymns and performing rituals dedicated to specific Yazatas."
      }
    ],
    "festivals": [
      {
        "name": "Nowruz",
        "timing": "Spring Equinox (March 20th or 21st)",
        "description": "Nowruz, the Persian New Year, is a celebration of renewal and the triumph of good over evil. It involves cleaning the house (Khaneh Tekani), preparing a special table with symbolic items (Haft-Seen), visiting family, and enjoying festive meals and gatherings. It marks the beginning of spring and a time of hope and new beginnings."
      },
      {
        "name": "Yalda Night",
        "timing": "Winter Solstice (December 20th or 21st)",
        "description": "Yalda Night, also known as Shab-e Chelleh, is the longest night of the year and is celebrated as the victory of light over darkness. Families gather together to eat special foods like pomegranates and watermelon, read poetry (especially Hafez), and stay awake until dawn to welcome the sun's return. It is a time for warmth, storytelling, and community."
      }
    ],
    "modernLegacy": "Persian mythology continues to inspire contemporary Iranian culture through literature, art, and film, often serving as a source of national identity and cultural pride. The stories of heroes like Rostam and the epic battles against evil forces are frequently retold and reinterpreted in modern contexts. Furthermore, the values and concepts embedded in Zoroastrianism, such as the importance of truth, justice, and good deeds, still resonate within Iranian society."
  },
