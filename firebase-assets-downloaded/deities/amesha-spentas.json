  "keyMyths": [
    {
      "title": "The Creation Myth: Ahura Mazda vs. Angra Mainyu",
      "description": "Ahura Mazda, the supreme god of goodness, creates the world and humanity. Angra Mainyu (Ahriman), the spirit of evil, constantly tries to corrupt and destroy this creation, leading to an eternal cosmic battle between good and evil.",
      "source": "Zoroastrian texts, particularly the Avesta"
    },
    {
      "title": "The Epic of Rostam",
      "description": "Rostam is the greatest hero of Persian mythology, known for his incredible strength, courage, and loyalty. His adventures, including slaying the White Demon and his tragic story with his son Sohrab, are central to the Shahnameh (Book of Kings).",
      "source": "Shahnameh (Book of Kings) by Ferdowsi"
    },
    {
      "title": "The Simurgh",
      "description": "The Simurgh is a benevolent, mythical bird, often depicted as a griffin-like creature with a peacock's tail. It possesses great wisdom and healing powers, and plays a crucial role in the lives of heroes like Zal, Rostam's father.",
      "source": "Various Persian literary and artistic traditions, including the Shahnameh"
    },
    {
      "title": "Yima and the Vara",
      "description": "Yima (Jamshid), a righteous king, is tasked by Ahura Mazda to build a Vara (enclosure) to protect the best of humanity, animals, and plants from a devastating winter brought about by Angra Mainyu. This myth explains how life was preserved through a cataclysmic event.",
      "source": "Zoroastrian texts, particularly the Vendidad"
    }
  ],
