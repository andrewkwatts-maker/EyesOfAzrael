  "keyMyths": [
    {
      "title": "Nanna's Journey to Nippur",
      "source": "Sumerian Hymn",
      "summary": "Nanna (Sin's Sumerian form) journeyed from Ur to Nippur by boat, laden with offerings for his father Enlil. At each city, he was greeted with gifts and prayers. At Nippur, Enlil blessed him with abundance, fertility, and dominion over the night.",
      "significance": "Establishes Sin's relationship with other gods and his role as bringer of prosperity"
    },
    {
      "title": "The Eclipse Demons",
      "source": "Babylonian Incantation Texts",
      "summary": "During lunar eclipses, demons attack Sin, attempting to devour him. The gods rally to his defense, and worshippers perform rituals to banish the darkness. Shamash and Ishtar fight alongside their father to restore his light.",
      "significance": "Explains lunar eclipses and the cosmic struggle between light and darkness"
    },
    {
      "title": "Sin and the Calendar",
      "source": "Enuma Elish",
      "summary": "Marduk assigned Sin to govern the night and regulate the months. His waxing and waning established the lunar calendar that structured all Mesopotamian religious and civic life. Each phase marked different ritual observances.",
      "significance": "Establishes Sin's role in cosmic order and time-keeping"
    }
  ],
