  "keyMyths": [
    {
      "title": "Thor's Fishing for Jormungandr",
      "description": "Thor went fishing with the giant Hymir and nearly pulled the Midgard Serpent from the ocean, intending to kill it."
    },
    {
      "title": "The Theft of Mjolnir",
      "description": "When the giant Thrym stole Thor's hammer, Thor disguised himself as Freyja to attend the wedding feast and slaughtered the giants."
    },
    {
      "title": "Thor's Journey to Utgard-Loki",
      "description": "Thor faced impossible challenges that were actually illusions, showing even the mightiest god faces limits."
    },
    {
      "title": "Thor and the World Serpent",
      "description": "Thor went fishing with the giant Hymir, using an ox head as bait. He hooked Jormungandr, the Midgard Serpent that encircles the world. As Thor prepared to strike, the terrified Hymir cut the line. Thor and Jormungandr are fated to face each other again at Ragnarok.",
      "source": "Hymiskvida (Poetic Edda); Gylfaginning"
    },
    {
      "title": "The Theft of Mjolnir",
      "description": "The giant Thrym stole Mjolnir and demanded Freya as bride for its return. Thor disguised himself as Freya, with Loki as his handmaiden. At the wedding feast, when Thrym brought out Mjolnir to bless the bride, Thor seized it and slaughtered all the giants present.",
      "source": "Thrymskvida (Poetic Edda)"
    }
  ],
